# Your EVM wallet address (Base / Polygon) — receives USDC payments
TREASURY_WALLET=0xYourEVMWalletHere

# Your Solana wallet address
TREASURY_WALLET_SOL=YourSolanaWalletHere

# Coinbase Developer Platform — for Base x402 verification
# https://portal.cdp.coinbase.com
CDP_API_KEY_ID=your-cdp-key-id
CDP_API_KEY_SECRET=your-cdp-key-secret

# Public URL of this agent
AGENT_ENDPOINT=https://your-agent.example.com/domain/lookup

# Port (optional, default: 3009)
PORT=3009
