# Your EVM wallet address (Base / Polygon) — receives USDC payments
TREASURY_WALLET=0xYourEVMWalletHere

# Your Solana wallet address — receives USDC payments on Solana
TREASURY_WALLET_SOL=YourSolanaWalletHere

# Coinbase Developer Platform API keys (for Base x402 verification)
# Get yours at: https://portal.cdp.coinbase.com
CDP_API_KEY_ID=your-cdp-key-id
CDP_API_KEY_SECRET=your-cdp-key-secret

# Public URL of this agent (used in payment requirements)
AGENT_ENDPOINT=https://your-agent.example.com/run

# Port (optional, defaults to 3010)
PORT=3010
